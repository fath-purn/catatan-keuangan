// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  role            String    @default("user")
  isEmailVerifeid Boolean   @default(false)
  code            String?
  codeExpires     DateTime?
  phone           String?

  // Custom Profile fields
  avatar          String @default("👦🏻")
  targetGayaHidup Float  @default(5000000)

  accounts     Account[]
  sessions     Session[]
  goals        Goal[]
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// model Goal untuk Target Menabung
model Goal {
  id              String   @id @default(cuid())
  nama            String
  icon            String   @default("🎯")
  target          Float
  terkumpul       Float    @default(0)
  tenggatWaktu    DateTime
  warnaBackground String   @default("#DBCBFF")
  motivasi        String?

  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// model Transaction untuk Pencatatan Keuangan
model Transaction {
  id              String   @id @default(cuid())
  nominal         Float
  judul           String
  tanggal         DateTime @default(now())
  waktu           String // e.g. "09:00"
  kategori        String // e.g. "Makanan", "Transportasi", "Pemasukan", "Tagihan"
  aset            String // e.g. "Cash", "BCA", "BNI", "OVO", "Gopay"
  mood            String   @default("Biasa") // "Biasa", "Senang", "Sedih", "Marah"
  keperluan       String // e.g. "Kebutuhan", "Impulsif", "Emergency", "Goals"
  jenis_transaksi Boolean // false = pengeluaran, true = pemasukan

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  goalId String?
  goal   Goal?   @relation(fields: [goalId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
